# Server Configuration
PORT=8080
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=your-secret-key-change-me-in-production

# Telegram Bot Configuration (Optional - can also be set via admin panel)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_NOTIFICATION_CHANNEL_ID=-1001234567890
TELEGRAM_ADMIN_APPROVAL_CHANNEL_ID=-1001234567891

# Database Configuration
DB_PATH=./storage/database.json

# Storage Paths
STORAGE_PATH=./storage
QR_CODE_PATH=./storage/qr_codes

# Admin Default Credentials (First-time setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Proxy Configuration (Optional - can also be set via admin panel)
# Format: username:password@host:port
DEFAULT_PROXY_URL=

# CebuPacific API Configuration (Optional - can also be set via admin panel)
CEBUPAC_API_KEY=

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
SESSION_HEARTBEAT_INTERVAL_SECONDS=30

# Rate Limiting
TOPUP_REQUEST_RATE_LIMIT=5
TOPUP_REQUEST_WINDOW_MINUTES=60

# File Upload Limits
MAX_RECEIPT_SIZE_MB=10
ALLOWED_RECEIPT_FORMATS=jpg,jpeg,png,pdf
